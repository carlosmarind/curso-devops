pipeline {
    agent any
    stages {
        stage("mi primer etapa"){
            steps{
                sh "echo 'este es mi primer pipeline desde jenkins'"
                sh "echo 'este es mi segundo mensaje dentro del pipeline desde jenkins'"
            }
        }
        stage("mi segunda etapa"){
            steps{
                sh "echo 'este es mi segunda etapa del pipeline desde jenkins'"
                sh "echo 'este es mi segunda etapa y mensaje mensaje dentro del pipeline desde jenkins'"
            }
        }
    }
}